# Flask settings
SECRET_KEY=your-secret-key-here
SESSION_SECRET=your-session-secret-here
DATABASE_URL=postgresql://user:password@localhost:5432/arbiontrader
FLASK_APP=wsgi.py
FLASK_DEBUG=0

# CRITICAL: Encryption Configuration (REQUIRED FOR PRODUCTION)
# Option 1 (Recommended): Use direct encryption key
ENCRYPTION_KEY=your-fernet-key-here
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Option 2: Use secret + salt for key derivation
# ENCRYPTION_SECRET=your-encryption-secret-here
# ENCRYPTION_SALT=your-encryption-salt-here
# Generate salt with: python -c "import secrets; print(secrets.token_hex(16))"

# Optional API credentials
# If provided these will be saved to the superadmin account
# the first time the application starts.
OPENAI_API_KEY=your-openai-key-here
COINBASE_API_KEY=your-coinbase-key-here
COINBASE_API_SECRET=your-coinbase-secret-here
COINBASE_API_PASSPHRASE=your-coinbase-passphrase-here

# Coinbase CDP Advanced Trade API (JWT / ES256 auth)
# Create at https://portal.cdp.coinbase.com/access/api
# The API secret is the EC private key in PEM format (keep the full -----BEGIN...END----- block)
CDP_API_KEY_NAME=organizations/{org_id}/apiKeys/{key_id}
CDP_API_KEY_SECRET=your-ec-private-key-pem-here
SCHWAB_CLIENT_ID=your-schwab-client-id-here
SCHWAB_CLIENT_SECRET=your-schwab-client-secret-here
SCHWAB_REDIRECT_URI=https://www.arbion.ai/oauth_callback/broker
SCHWAB_ACCESS_TOKEN=
SCHWAB_REFRESH_TOKEN=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Simulation mode
SIMULATION_MODE=false
CONFIDENCE_THRESHOLD=0.7

# Sentry
SENTRY_DSN=

# Superadmin account (optional)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=your-secure-password-here

# Sentiment Analysis
FINNHUB_API_KEY=your-finnhub-api-key-here
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here
# Reddit API (optional, for r/wallstreetbets, r/stocks, r/cryptocurrency sentiment)
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
REDDIT_USER_AGENT=ArbionTrader/1.0

# Session security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# AI Neural Engine Configuration
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
NEURAL_ENGINE_ENABLED=true
NEURAL_CONSENSUS_MODE=unanimous
NEURAL_CACHE_TTL=300
NEURAL_MAX_RETRIES=3
NEURAL_CONFIDENCE_THRESHOLD=0.4
